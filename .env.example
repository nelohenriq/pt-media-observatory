# PT Media Observatory Environment Variables
# This file contains example values for the required environment variables.
# Replace placeholder values with actual secrets before deployment.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=examplepassword
POSTGRES_DB=ptmedia
REDIS_PORT=6379
JWT_SECRET_KEY=super-secret-key
SSL_CERT_PATH=/etc/ssl/certs/fullchain.pem
SSL_KEY_PATH=/etc/ssl/certs/privkey.pem