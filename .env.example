# PT Media Observatory — Environment
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://postgres:examplepassword@localhost:5432/ptmedia

# JWT
JWT_SECRET=change-me-to-a-long-random-secret

# Internal API (used by cron poller and agent callbacks)
INTERNAL_API_KEY=dev-internal-key
BACKEND_URL=http://localhost:8000

# NVIDIA API (for model inference)
NVIDIA_API_KEY=nv-...(set from environment)